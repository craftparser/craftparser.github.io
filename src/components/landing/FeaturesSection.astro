---
const { data } = Astro.props;
---

<section id={data.id} class="py-20 bg-gray-800">
    <div class="max-w-screen-xl mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-white">{data.title}</h2>
            <p class="mt-4 text-gray-400 max-w-2xl mx-auto">{data.description}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {data.features.map((feature) => (
                <div class="p-6 bg-gray-700/50 rounded-xl border border-gray-600 hover:border-blue-500/50 transition-colors text-center">
                    <div class="text-4xl mb-4">{feature.icon}</div>
                    <h3 class="text-xl font-semibold text-white mb-2">{feature.title}</h3>
                    <p class="text-gray-400">{feature.description}</p>
                </div>
            ))}
        </div>
    </div>
</section>
