---
const { data } = Astro.props;
---

<section class="py-20 bg-gradient-to-r from-blue-900 to-purple-900">
    <div class="max-w-screen-xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{data.title}</h2>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-8">{data.description}</p>
        <a class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-white/10 rounded-lg hover:bg-white/20 transition-colors border border-white/20" href={data.href}>{data.action}</a>
    </div>
</section>
