---
interface Breadcrumb {
    label: string;
    href?: string;
}

const { items }: { items: Breadcrumb[] } = Astro.props;
---

<nav class="flex items-center flex-wrap gap-2 text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
    {items.map((item, index) => (
        <>
            {index > 0 && (
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
            )}
            {item.href ? (
                <a href={item.href} class="hover:text-blue-400 transition-colors">{item.label}</a>
            ) : (
                <span class="text-gray-300">{item.label}</span>
            )}
        </>
    ))}
</nav>
