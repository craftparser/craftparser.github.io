---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../func';

interface Props {
    post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
---

<a
    href={`/posts/${post.id}/`}
    class="block group bg-gray-700/50 hover:bg-gray-700 rounded-xl overflow-hidden transition-all duration-300 hover:shadow-lg hover:shadow-gray-900/50 hover:-translate-y-1"
>
    <div class="p-6">
        <div class="text-sm text-gray-400">{formatDate(post.data.pubDate)}</div>
        <h2 class="mt-2 text-xl font-bold text-gray-100 group-hover:text-blue-400 transition-colors line-clamp-2">{post.data.title}</h2>
        <p class="mt-3 text-gray-300 line-clamp-3">{post.data.description}</p>
        <div class="mt-4 flex items-center text-blue-400 group-hover:text-blue-300 transition-colors">
            <span class="text-sm font-medium">Читать далее →</span>
        </div>
    </div>
</a>
