---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../func";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: post,
    }));
}

const { Content } = await render(Astro.props);
const { data } = Astro.props;
---

<BaseLayout title={data.title} description={data.description}>
    <article class="container mx-auto px-4 py-12 max-w-3xl">
        <div class="mb-12 bg-gray-700 p-4 rounded-xl">
            <div class="text-sm text-gray-400">{formatDate(data.pubDate)}</div>
            <div class="mt-3 text-3xl font-bold text-gray-100">{data.title}</div>
            <div class="mt-3 text-lg text-gray-300">{data.description}</div>
        </div>
        <div class="prose prose-invert prose-lg max-w-none">
            <Content />
        </div>
    </article>
</BaseLayout>
