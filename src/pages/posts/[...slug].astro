---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Telegram from "../../assets/Telegram.svg";
import { POST_ACT_TITLE, POST_ACT_SUB, POST_ACT_BTN, ACTION_LINK } from "../../consts";
import { formatDate } from "../../func";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: post,
    }));
}

const { Content } = await render(Astro.props);
const { data } = Astro.props;
---

<BaseLayout title={data.title} description={data.description}>
    <article class="container mx-auto px-4 py-12 max-w-3xl">
        <div class="mb-12 bg-gray-700 p-4 rounded-xl">
            <div class="text-gray-400 text-sm">{formatDate(data.pubDate)}</div>
            <div class="text-gray-100 text-3xl mt-3 font-bold">{data.title}</div>
            <div class="text-gray-300 text-lg mt-3">{data.description}</div>
        </div>
        <div class="prose prose-invert prose-lg max-w-none">
            <Content />
        </div>
        <div class="mt-12 bg-gradient-to-r from-blue-900 to-purple-900 p-8 rounded-xl text-center">
            <div class="text-gray-100 text-2xl font-bold">{POST_ACT_TITLE}</div>
            <div class="text-blue-200 text-lg mt-3 mb-5">{POST_ACT_SUB}</div>
            <a class="text-white inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-500 font-bold rounded-lg transition-colors" href={ACTION_LINK}>
                <Telegram class="w-5 h-5" />
                {POST_ACT_BTN}
            </a>
        </div>
    </article>
</BaseLayout>
