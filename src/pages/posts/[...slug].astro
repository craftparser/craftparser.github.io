---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../func";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: post,
    }));
}

const { Content } = await render(Astro.props);
const { data } = Astro.props;
---

<BaseLayout title={data.title} description={data.description}>
    <article class="container mx-auto px-4 py-12 max-w-3xl">
        <header class="mb-8">
            <div class="text-sm text-gray-400">{formatDate(data.pubDate)}</div>
            <h1 class="mt-3 text-3xl font-bold text-gray-100">{data.title}</h1>
            <p class="mt-3 text-lg text-gray-300">{data.description}</p>
        </header>
        <div class="prose prose-invert prose-lg max-w-none">
            <Content />
        </div>
        <footer class="mt-12 pt-8 border-t border-gray-700">
            <a href="/posts/" class="inline-block text-blue-400 hover:text-blue-300 transition-colors">
                ← Назад к списку постов
            </a>
        </footer>
    </article>
</BaseLayout>
