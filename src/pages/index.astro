---
import BaseLayout from "../layouts/BaseLayout.astro";
import { INDEX_TITLE, INDEX_DESCR, INDEX_H1 } from "../consts";

const FEATURES = [
    { icon: "⚡", title: "Высокая скорость", description: "Обрабатываем тысячи страниц в минуту. Экономим ваше время на сбор данных." },
    { icon: "🎯", title: "Точность 99%+",    description: "Гарантируем точность извлечения данных. Многоуровневая валидация результатов." },
    { icon: "📊", title: "Любые форматы",    description: "Выгрузка в Excel, CSV, JSON, XML. Интеграция с вашей CRM или базой данных." },
    { icon: "🔒", title: "Обход защит",      description: "Обходим блокировки и капчу. Работаем с авторизацией и сложными сайтами." },
    { icon: "🔄", title: "Автообновление",   description: "Настроим регулярный парсинг по расписанию. Актуальные данные всегда под рукой." },
    { icon: "💼", title: "Поддержка 24/7",   description: "Техническая поддержка и консультации. Поможем интегрировать данные в ваши процессы." },
];

const PRICING = [
    {
        name: "Старт",
        price: "от 5 000 ₽",
        description: "Для небольших проектов",
        features: [
            "Парсинг до 1 000 страниц",
            "Базовая структура данных",
            "Выгрузка в CSV/Excel",
            "Срок: 2-3 дня",
            "Консультация",
        ],
        highlighted: false,
    },
    {
        name: "Бизнес",
        price: "от 15 000 ₽",
        description: "Для средних компаний",
        features: [
            "Парсинг до 100 000 страниц",
            "Сложная структура данных",
            "Любые форматы (JSON, XML, CSV)",
            "Срок: 5-7 дней",
            "Приоритетная поддержка",
            "Настройка автообновления",
        ],
        highlighted: true,
    },
    {
        name: "Корпоратив",
        price: "от 50 000 ₽",
        description: "Для крупных проектов",
        features: [
            "Без ограничений по объёму",
            "Индивидуальная разработка",
            "Интеграция с вашей системой",
            "Срок: от 10 дней",
            "Персональный менеджер",
            "SLA и гарантия uptime",
        ],
        highlighted: false,
    },
];
---

<BaseLayout title={INDEX_TITLE} description={INDEX_DESCR}>
    <section class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-blue-900">
        <div class="max-w-screen-xl mx-auto px-6 py-20 lg:py-32">
            <div class="text-center">
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
                    <div>{INDEX_H1[0]}</div>
                    <div class="text-blue-400">{INDEX_H1[1]}</div>
                </h1>
                <p class="mt-6 text-lg md:text-xl text-gray-300 max-w-3xl mx-auto">
                    Автоматизируем сбор информации с сайтов: товары, цены, контакты, аналитика.
                    Получайте данные в удобном формате для вашего бизнеса.
                </p>
                <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-lg shadow-blue-600/30">
                        Заказать парсинг
                    </a>
                    <a href="#features" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-gray-300 bg-gray-700/50 rounded-lg hover:bg-gray-700 transition-colors border border-gray-600">
                        Узнать подробнее
                    </a>
                </div>
            </div>
        </div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl"></div>
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl"></div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-20 bg-gray-800">
        <div class="max-w-screen-xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-white">Почему выбирают нас</h2>
                <p class="mt-4 text-gray-400 max-w-2xl mx-auto">
                    Профессиональный подход к сбору и обработке данных
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {FEATURES.map((feature) => (
                    <div class="p-6 bg-gray-700/50 rounded-xl border border-gray-600 hover:border-blue-500/50 transition-colors">
                        <div class="text-4xl mb-4">{feature.icon}</div>
                        <h3 class="text-xl font-semibold text-white mb-2">{feature.title}</h3>
                        <p class="text-gray-400">{feature.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="py-20 bg-gray-900">
        <div class="max-w-screen-xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-white">Тарифные планы</h2>
                <p class="mt-4 text-gray-400 max-w-2xl mx-auto">
                    Выберите подходящий вариант для вашего проекта
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {PRICING.map((plan) => (
                    <div class={`relative p-8 rounded-2xl border ${plan.highlighted ? 'bg-gray-800 border-blue-500 shadow-xl shadow-blue-500/10' : 'bg-gray-800/50 border-gray-700'} flex flex-col`}>
                        {plan.highlighted && (
                            <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-blue-600 text-white text-sm font-semibold rounded-full">
                                Популярный
                            </div>
                        )}
                        <div class="text-center mb-6">
                            <h3 class="text-2xl font-bold text-white">{plan.name}</h3>
                            <p class="text-gray-400 mt-2">{plan.description}</p>
                            <div class="mt-4 text-3xl font-bold text-blue-400">{plan.price}</div>
                        </div>
                        <ul class="space-y-4 mb-8 flex-1">
                            {plan.features.map((feature) => (
                                <li class="flex items-start gap-3 text-gray-300">
                                    <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                    </svg>
                                    <span>{feature}</span>
                                </li>
                            ))}
                        </ul>
                        <a href="#contact" class={`w-full py-3 px-6 text-center font-semibold rounded-lg transition-colors ${plan.highlighted ? 'bg-blue-600 text-white hover:bg-blue-700' : 'bg-gray-700 text-gray-300 hover:bg-gray-600'}`}>
                            Заказать
                        </a>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-gradient-to-r from-blue-900 to-purple-900">
        <div class="max-w-screen-xl mx-auto px-6 text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Готовы начать?</h2>
            <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-8">
                Оставьте заявку и получите бесплатную консультацию. Обсудим ваш проект и подберём оптимальное решение.
            </p>
            <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-white/10 rounded-lg hover:bg-white/20 transition-colors border border-white/20">
                Обсудить проект
            </a>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-20 bg-gray-800">
        <div class="max-w-screen-xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-white">Свяжитесь с нами</h2>
                <p class="mt-4 text-gray-400 max-w-2xl mx-auto">
                    Обсудим ваш проект и ответим на все вопросы
                </p>
            </div>
            <div class="max-w-2xl mx-auto">
                <form class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Имя</label>
                            <input type="text" id="name" name="name" class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Ваше имя" />
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Email</label>
                            <input type="email" id="email" name="email" class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="your@email.com" />
                        </div>
                    </div>
                    <div>
                        <label for="message" class="block text-sm font-medium text-gray-300 mb-2">Сообщение</label>
                        <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" placeholder="Опишите ваш проект..."></textarea>
                    </div>
                    <button type="submit" class="w-full py-4 px-6 text-lg font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-lg shadow-blue-600/30">
                        Отправить заявку
                    </button>
                </form>
                <div class="mt-12 text-center">
                    <p class="text-gray-400 mb-4">Или напишите нам напрямую:</p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a href="mailto:hello@craftparser.com" class="text-blue-400 hover:text-blue-300 transition-colors">hello@craftparser.com</a>
                        <span class="text-gray-600 hidden sm:inline">•</span>
                        <a href="https://t.me/craftparser" class="text-blue-400 hover:text-blue-300 transition-colors">@craftparser</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
