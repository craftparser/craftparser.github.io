---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaSection from "../components/landing/CtaSection.astro";
import FeaturesSection from "../components/landing/FeaturesSection.astro";
import HeroSection from "../components/landing/HeroSection.astro";
import PricingSection from "../components/landing/PricingSection.astro";
import { INDEX_TITLE, INDEX_DESCR, ACTION_LINK } from "../consts";
---

<BaseLayout title={INDEX_TITLE} description={INDEX_DESCR}>
    <HeroSection
        data={{
            id: "hero",
            title_1: "Парсинг данных",
            title_2: "из любых источников",
            description: "Быстро соберем данные с Wildberries, Яндекс Карт, поисковиков и соцсетей. Вы получаете готовый результат в Excel без необходимости разбираться в софте и прокси.",
            label_1: "Рассчитать стоимость",
            label_2: "Узнать подробнее",
            href_1: ACTION_LINK,
            href_2: "#features",
        }}
    />

    <FeaturesSection
        data={{
            id: "features",
            title: "Почему выбирают нас",
            description: "Профессиональный подход к сбору и обработке данных",
            features: [
                { icon: "🛍️", title: "Маркетплейсы",        description: "Цены, остатки, отзывы и характеристики товаров с Wildberries, AliExpress, Amazon и Яндекс Маркета." },
                { icon: "📍", title: "Карты и Справочники", description: "Сбор контактов, адресов и рейтингов компаний с Яндекс Карт и Google Maps." },
                { icon: "🔍", title: "Поисковая выдача",    description: "Сбор SEO-данных, сниппетов и позиций из Google и Яндекс по любым запросам." },
                { icon: "🕵️", title: "Мониторинг цен",      description: "Слежение за ценами конкурентов в интернет-магазинах для быстрой переоценки вашего товара." },
                { icon: "🏢", title: "Базы контактов",      description: "Сбор email, телефонов и соцсетей из открытых источников для ваших отделов продаж." },
                { icon: "🚀", title: "Масштабируемость",    description: "Благодаря многопоточности, соберем миллионы строк данных в кратчайшие сроки." },
            ],
        }}
    />

    <PricingSection
        data={{
            id: "pricing",
            title: "Стоимость услуг",
            description: "Финальная цена зависит от сложности сайта и объема данных",
            pricing: [
                {
                    name: "Базовый",
                    price: "от 1 000 ₽",
                    description: "Для простых задач",
                    features: [
                        "Сбор данных с 1 сайта",
                        "До 10 000 строк",
                        "Простая структура",
                        "Выгрузка в Excel/CSV",
                        "Срок: 1-2 дня",
                    ],
                    highlighted: false,
                }, {
                    name: "Маркетплейсы",
                    price: "от 5 000 ₽",
                    description: "Глубокая аналитика",
                    features: [
                        "WB, AliExpress, Яндекс Маркет",
                        "Парсинг цен и остатков",
                        "Сбор отзывов и фото",
                        "Обход защит и капчи",
                        "Срок: 2-4 дня",
                        "Приоритетная поддержка",
                    ],
                    highlighted: true,
                }, {
                    name: "Регулярный",
                    price: "По запросу",
                    description: "Для постоянного мониторинга",
                    features: [
                        "Обновление данных по графику",
                        "Отслеживание изменений цен",
                        "Прямая интеграция в Google Sheets",
                        "Любые объемы данных",
                        "Индивидуальный формат",
                        "Персональный менеджер",
                    ],
                    highlighted: false,
                },
            ],
            top: "Популярный",
            action: "Заказать расчет",
            href: ACTION_LINK,
        }}
    />

    <CtaSection
        data={{
            id: "contact",
            title: "Нужны данные уже завтра?",
            description: "Просто пришлите ссылку на сайт и список нужных полей. Мы проведем тестовый сбор нескольких строк бесплатно, чтобы вы оценили качество.",
            action: "Написать в Telegram",
            href: ACTION_LINK,
        }}
    />
</BaseLayout>
