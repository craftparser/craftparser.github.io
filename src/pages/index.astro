---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaSection from "../components/landing/CtaSection.astro";
import FeaturesSection from "../components/landing/FeaturesSection.astro";
import HeroSection from "../components/landing/HeroSection.astro";
import PricingSection from "../components/landing/PricingSection.astro";
import { INDEX_TITLE, INDEX_DESCR, INDEX_H1 } from "../consts";
---

<BaseLayout title={INDEX_TITLE} description={INDEX_DESCR}>
    <HeroSection
        data={{
            title_1: INDEX_H1[0],
            title_2: INDEX_H1[1],
            description: "Автоматизируем сбор информации с сайтов: товары, цены, контакты, аналитика. Получайте данные в удобном формате для вашего бизнеса.",
            btn_left_label: "Заказать парсинг",
            btn_left_href: "#contact",
            btn_right_label: "Узнать подробнее",
            btn_right_href: "#features",
        }}
    />

    <FeaturesSection
        data={{
            id: "features",
            title: "Почему выбирают нас",
            description: "Профессиональный подход к сбору и обработке данных",
            features: [
                { icon: "⚡", title: "Высокая скорость", description: "Обрабатываем тысячи страниц в минуту. Экономим ваше время на сбор данных." },
                { icon: "🎯", title: "Точность 99%+",    description: "Гарантируем точность извлечения данных. Многоуровневая валидация результатов." },
                { icon: "📊", title: "Любые форматы",    description: "Выгрузка в Excel, CSV, JSON, XML. Интеграция с вашей CRM или базой данных." },
                { icon: "🔒", title: "Обход защит",      description: "Обходим блокировки и капчу. Работаем с авторизацией и сложными сайтами." },
                { icon: "🔄", title: "Автообновление",   description: "Настроим регулярный парсинг по расписанию. Актуальные данные всегда под рукой." },
                { icon: "💼", title: "Поддержка 24/7",   description: "Техническая поддержка и консультации. Поможем интегрировать данные в ваши процессы." },
            ],
        }}
    />

    <PricingSection
        data={{
            id: "pricing",
            title: "Тарифные планы",
            description: "Выберите подходящий вариант для вашего проекта",
            pricing: [
                {
                    name: "Старт",
                    price: "от 5 000 ₽",
                    description: "Для небольших проектов",
                    features: [
                        "Парсинг до 1 000 страниц",
                        "Базовая структура данных",
                        "Выгрузка в CSV/Excel",
                        "Срок: 2-3 дня",
                        "Консультация",
                    ],
                    highlighted: false,
                }, {
                    name: "Бизнес",
                    price: "от 15 000 ₽",
                    description: "Для средних компаний",
                    features: [
                        "Парсинг до 100 000 страниц",
                        "Сложная структура данных",
                        "Любые форматы (JSON, XML, CSV)",
                        "Срок: 5-7 дней",
                        "Приоритетная поддержка",
                        "Настройка автообновления",
                    ],
                    highlighted: true,
                }, {
                    name: "Корпоратив",
                    price: "от 50 000 ₽",
                    description: "Для крупных проектов",
                    features: [
                        "Без ограничений по объёму",
                        "Индивидуальная разработка",
                        "Интеграция с вашей системой",
                        "Срок: от 10 дней",
                        "Персональный менеджер",
                        "SLA и гарантия uptime",
                    ],
                    highlighted: false,
                },
            ],
            action: "Заказать",
            top: "Популярный",
        }}
    />

    <CtaSection
        data={{
            title: "Готовы начать?",
            description: "Оставьте заявку и получите бесплатную консультацию. Обсудим ваш проект и подберём оптимальное решение.",
            action: "Обсудить проект",
            href: "#contact",
        }}
    />

    <!-- Contact Section -->
    <section id="contact" class="py-20 bg-gray-800">
        <div class="max-w-screen-xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-white">Свяжитесь с нами</h2>
                <p class="mt-4 text-gray-400 max-w-2xl mx-auto">
                    Обсудим ваш проект и ответим на все вопросы
                </p>
            </div>
            <div class="max-w-2xl mx-auto">
                <form class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label for="name" class="block text-sm font-medium text-gray-300 mb-2">Имя</label>
                            <input type="text" id="name" name="name" class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Ваше имя" />
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Email</label>
                            <input type="email" id="email" name="email" class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="your@email.com" />
                        </div>
                    </div>
                    <div>
                        <label for="message" class="block text-sm font-medium text-gray-300 mb-2">Сообщение</label>
                        <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" placeholder="Опишите ваш проект..."></textarea>
                    </div>
                    <button type="submit" class="w-full py-4 px-6 text-lg font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-lg shadow-blue-600/30">
                        Отправить заявку
                    </button>
                </form>
                <div class="mt-12 text-center">
                    <p class="text-gray-400 mb-4">Или напишите нам напрямую:</p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a href="mailto:hello@craftparser.com" class="text-blue-400 hover:text-blue-300 transition-colors">hello@craftparser.com</a>
                        <span class="text-gray-600 hidden sm:inline">•</span>
                        <a href="https://t.me/craftparser" class="text-blue-400 hover:text-blue-300 transition-colors">@craftparser</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
